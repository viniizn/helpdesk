{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@helpdesk/shared": ["../../packages/shared/src/index.ts"]
    },
    "exactOptionalPropertyTypes": false
  },
  "include": ["src/**/*"]
}